<script>
/* ── SCROLL REVEAL ── */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
  });
}, { threshold: 0.07, rootMargin: '0px 0px -24px 0px' });
document.querySelectorAll('.anim').forEach(el => io.observe(el));

/* ── PROJECT ACCORDION ── */
document.querySelectorAll('.proj').forEach(proj => {
  proj.querySelector('.proj-header').addEventListener('click', () => {
    const isOpen = proj.classList.contains('open');
    document.querySelectorAll('.proj').forEach(p => p.classList.remove('open'));
    if (!isOpen) proj.classList.add('open');
  });
});

/* ── SKILLS TABS ── */
document.querySelectorAll('.sk-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    const key = tab.dataset.tab;
    document.querySelectorAll('.sk-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.sk-pane').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    const pane = document.getElementById('pane-' + key);
    if (pane) {
      pane.classList.add('active');
      pane.querySelectorAll('.sk').forEach((el, i) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(6px)';
        setTimeout(() => {
          el.style.transition = 'opacity 250ms ease, transform 250ms ease';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, i * 14);
      });
    }
  });
});

/* ── COUNTER ANIMATION ── */
function easeOut(t) { return 1 - Math.pow(1 - t, 3); }
const cio = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target;
    const target = parseFloat(el.dataset.count);
    const suffix = el.dataset.suffix || '';
    if (isNaN(target)) { cio.unobserve(el); return; }
    const dur = 1300;
    const start = performance.now();
    (function tick(now) {
      const p = Math.min((now - start) / dur, 1);
      el.textContent = Math.round(easeOut(p) * target) + suffix;
      if (p < 1) requestAnimationFrame(tick);
    })(start);
    cio.unobserve(el);
  });
}, { threshold: 0.6 });
document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));

/* ── NAV SCROLL SHRINK ── */
const nav = document.querySelector('.nav');
window.addEventListener('scroll', () => {
  nav.style.height = window.scrollY > 60 ? '50px' : '';
}, { passive: true });
</script>
