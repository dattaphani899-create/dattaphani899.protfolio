<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Phani Datta — Senior QA Engineer preventing EV charging failures across hardware, firmware, and cloud systems at scale. OCPP · ISO 15118 · HIL/SIL · Python Automation.">
<title>Phani Datta · Senior QA Engineer · EV Charging Systems</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&family=Geist+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ─── RESET ─── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

/* ─── DESIGN TOKENS ─── */
:root{
  --void:#07090C;
  --raised:#0D1117;
  --surface:#131920;
  --overlay:#19212B;
  --rim:rgba(255,255,255,0.06);
  --rim-h:rgba(255,255,255,0.11);
  --t1:#EDF2F7;
  --t2:#7A8FA0;
  --t3:#415060;
  --cyan:#14BED4;
  --cyan-d:rgba(20,190,212,0.08);
  --em:#00C47A;
  --em-d:rgba(0,196,122,0.08);
  --am:#F59E0B;
  --am-d:rgba(245,158,11,0.08);
  --serif:'Instrument Serif',Georgia,serif;
  --sans:'Geist',system-ui,sans-serif;
  --mono:'Geist Mono','Menlo',monospace;
  --nav-h:60px;
  --max:1100px;
  --g:clamp(20px,5vw,60px);
  --ease:cubic-bezier(0.16,1,0.3,1);
}

/* ─── BASE ─── */
html{scroll-behavior:smooth;scroll-padding-top:calc(var(--nav-h) + 12px)}
body{background:var(--void);color:var(--t1);font-family:var(--sans);font-size:16px;line-height:1.65;-webkit-font-smoothing:antialiased;overflow-x:hidden}
::selection{background:rgba(20,190,212,0.18);color:var(--t1)}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--overlay);border-radius:3px}

/* ─── AMBIENT (very subtle, no performance impact) ─── */
.amb{position:fixed;border-radius:50%;pointer-events:none;z-index:0;filter:blur(120px)}
.amb-1{width:500px;height:500px;background:radial-gradient(circle,rgba(20,190,212,0.03) 0%,transparent 70%);top:-120px;right:-100px}
.amb-2{width:400px;height:400px;background:radial-gradient(circle,rgba(0,196,122,0.02) 0%,transparent 70%);bottom:15%;left:-100px}

/* ─── NAV ─── */
.nav{
  position:fixed;top:0;left:0;right:0;height:var(--nav-h);z-index:900;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 var(--g);max-width:calc(var(--max) + var(--g)*2);margin:0 auto;
}
.nav::before{
  content:'';position:absolute;inset:0;background:rgba(7,9,12,0.88);
  backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);
  border-bottom:1px solid var(--rim);z-index:-1;
}
.nav-logo{font-family:var(--serif);font-size:1.1rem;font-style:italic;color:var(--t1);text-decoration:none}
.nav-links{display:flex;align-items:center;gap:30px}
.nav-link{font-size:0.81rem;color:var(--t2);text-decoration:none;transition:color 160ms}
.nav-link:hover{color:var(--t1)}
.nav-cta{font-family:var(--mono);font-size:0.7rem;letter-spacing:0.05em;color:var(--t1);text-decoration:none;border:1px solid var(--rim-h);padding:7px 16px;border-radius:100px;transition:all 160ms;white-space:nowrap}
.nav-cta:hover{border-color:var(--cyan);color:var(--cyan);background:var(--cyan-d)}

/* ─── LAYOUT ─── */
.wrap{max-width:var(--max);margin:0 auto;padding:0 var(--g);position:relative;z-index:1}
.section{padding:clamp(64px,9vw,120px) 0}
.divider{height:1px;background:var(--rim);position:relative;z-index:1}

/* ─── TYPE ─── */
.eyebrow{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:0.66rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--cyan);margin-bottom:16px}
.eyebrow::before{content:'';width:16px;height:1px;background:var(--cyan);flex-shrink:0}
.h2{font-family:var(--serif);font-size:clamp(1.9rem,3.2vw,2.8rem);font-weight:400;letter-spacing:-0.025em;line-height:1.1;color:var(--t1)}
.h2 em{font-style:italic;color:var(--t2)}
.mono-sm{font-family:var(--mono);font-size:0.7rem;color:var(--t3);letter-spacing:0.04em}

/* ─── BUTTONS ─── */
.btn{display:inline-flex;align-items:center;gap:8px;font-size:0.83rem;font-weight:500;text-decoration:none;border-radius:100px;padding:11px 22px;transition:all 160ms var(--ease);white-space:nowrap}
.btn-p{background:var(--t1);color:var(--void)}
.btn-p:hover{background:#fff;transform:translateY(-1px);box-shadow:0 6px 24px rgba(237,242,247,0.1)}
.btn-g{background:transparent;color:var(--t2);border:1px solid var(--rim-h)}
.btn-g:hover{color:var(--t1);background:var(--raised);transform:translateY(-1px)}
.btn-link{display:inline-flex;align-items:center;gap:5px;font-family:var(--mono);font-size:0.7rem;letter-spacing:0.06em;text-transform:uppercase;color:var(--cyan);text-decoration:none;border-bottom:1px solid rgba(20,190,212,0.25);padding:5px 0;transition:border-color 160ms}
.btn-link:hover{border-color:var(--cyan)}

/* ════════════════════════════════════
   HERO
════════════════════════════════════ */
.hero{min-height:100svh;display:flex;align-items:center;padding-top:var(--nav-h);position:relative}
.hero-inner{max-width:var(--max);width:100%;padding:0 var(--g);display:grid;grid-template-columns:1fr 390px;gap:60px;align-items:center}

/* status pill */
.hero-pill{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:0.66rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--em);margin-bottom:24px}
.hero-pill-dot{width:6px;height:6px;background:var(--em);border-radius:50%;position:relative;flex-shrink:0}
.hero-pill-dot::after{content:'';position:absolute;inset:-3px;border-radius:50%;background:var(--em);opacity:0.3;animation:ping 2s ease-in-out infinite}
@keyframes ping{0%,100%{transform:scale(1);opacity:0.3}50%{transform:scale(2.2);opacity:0}}

/* headline */
.hero-hook{font-family:var(--serif);font-size:clamp(2.5rem,5vw,4.2rem);font-weight:400;letter-spacing:-0.035em;line-height:0.97;color:var(--t1);margin-bottom:16px}
.hero-hook em{font-style:italic;color:var(--cyan)}

/* ONE-LINE VALUE PROP — new */
.hero-prop{font-size:0.95rem;color:var(--t2);font-weight:300;line-height:1.6;margin-bottom:20px;max-width:480px;border-left:2px solid var(--cyan);padding-left:14px}
.hero-prop strong{color:var(--t1);font-weight:500}

.hero-sub{font-size:0.95rem;color:var(--t2);line-height:1.75;font-weight:300;margin-bottom:32px;max-width:460px}
.hero-sub strong{color:var(--t1);font-weight:500}
.hero-ctas{display:flex;gap:10px;flex-wrap:wrap}

/* quick scan card */
.qscan{background:var(--raised);border:1px solid var(--rim);border-radius:14px;overflow:hidden}
.qscan-head{padding:14px 18px;border-bottom:1px solid var(--rim);display:flex;align-items:center;gap:8px}
.qscan-dot{width:6px;height:6px;border-radius:50%;background:var(--em);animation:ping 2s ease-in-out infinite}
.qscan-title{font-family:var(--mono);font-size:0.63rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--t3)}
.qscan-row{display:flex;align-items:flex-start;gap:12px;padding:13px 18px;border-bottom:1px solid var(--rim);transition:background 150ms}
.qscan-row:last-child{border-bottom:none}
.qscan-row:hover{background:var(--surface)}
.qscan-icon{font-size:0.88rem;flex-shrink:0;margin-top:1px}
.qscan-label{font-size:0.83rem;font-weight:500;color:var(--t1);line-height:1.3;margin-bottom:2px}
.qscan-meta{font-family:var(--mono);font-size:0.64rem;color:var(--t3);letter-spacing:0.02em}

/* scroll hint */
.hero-scroll{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fadein 1s var(--ease) 2s forwards}
.scroll-track{width:1px;height:36px;background:var(--rim);overflow:hidden}
.scroll-fill{height:50%;background:linear-gradient(to bottom,var(--cyan),transparent);animation:scrollpulse 2s var(--ease) infinite}
@keyframes scrollpulse{0%{transform:translateY(-100%)}100%{transform:translateY(200%)}}
.scroll-lbl{font-family:var(--mono);font-size:0.58rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--t3)}

/* ════════════════════════════════════
   IMPACT AT SCALE STRIP
════════════════════════════════════ */
.impact-strip{position:relative;z-index:1;background:var(--raised);border-top:1px solid var(--rim);border-bottom:1px solid var(--rim)}
.impact-strip-inner{max-width:var(--max);margin:0 auto;padding:0 var(--g)}

/* header row */
.impact-header{padding:20px 0 0;display:flex;align-items:center;gap:12px}
.impact-header-label{font-family:var(--mono);font-size:0.66rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--t3)}
.impact-header-rule{flex:1;height:1px;background:var(--rim)}

/* metrics row */
.metrics-row{display:grid;grid-template-columns:repeat(4,1fr)}
.metric{padding:24px 20px;border-right:1px solid var(--rim);transition:background 160ms;position:relative}
.metric:last-child{border-right:none}
.metric:hover{background:var(--surface)}
.metric-num{font-family:var(--serif);font-size:2.2rem;font-weight:400;letter-spacing:-0.04em;line-height:1;margin-bottom:4px;color:var(--t1)}
.metric-num.c{color:var(--cyan)}
.metric-num.e{color:var(--em)}
.metric-num.a{color:var(--am)}
.metric-label{font-size:0.84rem;font-weight:500;color:var(--t1);margin-bottom:3px}
/* ENHANCED: metric meaning — shows business consequence */
.metric-meaning{font-family:var(--mono);font-size:0.64rem;color:var(--em);letter-spacing:0.01em;line-height:1.4;margin-bottom:4px;font-style:italic}
.metric-desc{font-family:var(--mono);font-size:0.63rem;color:var(--t3);letter-spacing:0.01em;line-height:1.45}

/* "Impact at scale" inline callout */
.impact-callout{
  border-top:1px solid var(--rim);padding:16px 0 20px;
  display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap;
}
.impact-callout-label{font-family:var(--mono);font-size:0.63rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--cyan);white-space:nowrap;padding-top:1px}
.impact-chips{display:flex;flex-wrap:wrap;gap:8px}
.impact-chip{
  font-family:var(--mono);font-size:0.67rem;letter-spacing:0.02em;
  color:var(--t2);background:var(--surface);border:1px solid var(--rim);
  padding:5px 12px;border-radius:6px;
}
.impact-chip strong{color:var(--t1);font-weight:500}

/* ════════════════════════════════════
   MARQUEE
════════════════════════════════════ */
.mq{position:relative;z-index:1;border-top:1px solid var(--rim);border-bottom:1px solid var(--rim);background:var(--raised);overflow:hidden;padding:13px 0}
.mq-inner{display:flex;width:max-content;animation:mq 36s linear infinite}
.mq-group{display:flex;align-items:center}
.mq-item{font-family:var(--mono);font-size:0.67rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--t3);padding:0 26px;white-space:nowrap}
.mq-sep{color:var(--cyan);font-size:0.45rem}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ════════════════════════════════════
   DIFFERENTIATOR
════════════════════════════════════ */
.diff-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;border:1px solid var(--rim);border-radius:14px;overflow:hidden;background:var(--rim)}
.diff-card{background:var(--raised);padding:28px;transition:background 160ms}
.diff-card:hover{background:var(--surface)}
.diff-icon{font-size:1.4rem;margin-bottom:12px}
.diff-title{font-family:var(--serif);font-size:1.1rem;font-weight:400;letter-spacing:-0.01em;color:var(--t1);margin-bottom:7px}
.diff-body{font-size:0.86rem;color:var(--t2);line-height:1.68;font-weight:300}

/* ════════════════════════════════════
   PROJECTS
════════════════════════════════════ */
.proj-list{display:flex;flex-direction:column;gap:2px;border:1px solid var(--rim);border-radius:14px;overflow:hidden;background:var(--rim)}
.proj{background:var(--raised);overflow:hidden;transition:background 280ms var(--ease)}
.proj:hover{background:var(--surface)}

/* header */
.proj-header{display:grid;grid-template-columns:48px 1fr auto;gap:18px;align-items:center;padding:24px 28px;cursor:pointer}
.proj-num{font-family:var(--serif);font-size:1.7rem;font-style:italic;color:var(--t3);line-height:1;transition:color 180ms}
.proj:hover .proj-num,.proj.open .proj-num{color:var(--cyan)}
.proj-headline-row{display:flex;align-items:center;gap:9px;margin-bottom:3px;flex-wrap:wrap}
.proj-name{font-family:var(--serif);font-size:1.15rem;font-weight:400;letter-spacing:-0.01em;color:var(--t1);line-height:1.2}
.badge{font-family:var(--mono);font-size:0.58rem;letter-spacing:0.07em;text-transform:uppercase;padding:3px 8px;border-radius:100px;border:1px solid;white-space:nowrap}
.bc{color:var(--cyan);border-color:rgba(20,190,212,0.3);background:var(--cyan-d)}
.be{color:var(--em);border-color:rgba(0,196,122,0.3);background:var(--em-d)}
.ba{color:var(--am);border-color:rgba(245,158,11,0.3);background:var(--am-d)}

/* KEY IMPACT bullets — new, always visible */
.proj-key-impact{
  display:flex;flex-wrap:wrap;gap:6px;margin-bottom:5px;
}
.proj-ki{
  font-family:var(--mono);font-size:0.62rem;letter-spacing:0.02em;
  color:var(--em);background:var(--em-d);border:1px solid rgba(0,196,122,0.18);
  padding:3px 9px;border-radius:5px;white-space:nowrap;
}

.proj-biz{font-size:0.82rem;color:var(--t2);font-weight:300;font-style:italic;margin-bottom:4px}
.proj-meta{font-family:var(--mono);font-size:0.66rem;color:var(--t3);letter-spacing:0.02em}
.proj-toggle{width:28px;height:28px;border:1px solid var(--rim-h);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:0.78rem;transition:all 280ms var(--ease);flex-shrink:0}
.proj.open .proj-toggle{background:var(--cyan-d);border-color:rgba(20,190,212,0.3);color:var(--cyan);transform:rotate(45deg)}

/* accordion */
.proj-body{display:grid;grid-template-rows:0fr;transition:grid-template-rows 480ms var(--ease)}
.proj.open .proj-body{grid-template-rows:1fr}
.proj-body-inner{overflow:hidden}
.proj-content{border-top:1px solid var(--rim);padding:24px 28px;display:grid;grid-template-columns:1fr 1fr;gap:20px 36px}

.cl{font-family:var(--mono);font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--cyan);margin-bottom:7px}
.ct{font-size:0.87rem;color:var(--t2);line-height:1.7;font-weight:300}
.ct strong{color:var(--t1);font-weight:500}
.ct ul{padding-left:14px;display:flex;flex-direction:column;gap:3px;list-style:disc}
.ct ul li{color:var(--t2);font-size:0.87rem}

.chips{display:flex;flex-wrap:wrap;gap:5px}
.chip{font-family:var(--mono);font-size:0.63rem;color:var(--t3);background:var(--surface);border:1px solid var(--rim);padding:3px 9px;border-radius:5px;transition:all 160ms}
.proj.open .chip{border-color:var(--rim-h);color:var(--t2)}

.impact-box{grid-column:1/-1;background:var(--surface);border:1px solid var(--rim);border-radius:9px;padding:14px 18px;display:flex;align-items:flex-start;gap:10px}
.impact-arrow{color:var(--em);font-weight:600;flex-shrink:0;margin-top:1px;font-size:0.9rem}
.impact-body{font-size:0.87rem;color:var(--t1);line-height:1.55}
.impact-body strong{color:var(--em)}
.proj-links{grid-column:1/-1;display:flex;gap:18px;padding-top:2px}

/* ════════════════════════════════════
   RETOOL / INTERNAL TOOLS SECTION
════════════════════════════════════ */
.tools-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;border:1px solid var(--rim);border-radius:14px;overflow:hidden;background:var(--rim)}
.tool-card{background:var(--raised);padding:24px;transition:background 160ms}
.tool-card:hover{background:var(--surface)}
.tool-card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.tool-icon{font-size:1.3rem}
.tool-badge{font-family:var(--mono);font-size:0.58rem;letter-spacing:0.07em;text-transform:uppercase;padding:3px 8px;border-radius:5px;color:var(--cyan);background:var(--cyan-d);border:1px solid rgba(20,190,212,0.2)}
.tool-title{font-family:var(--serif);font-size:1rem;font-weight:400;letter-spacing:-0.01em;color:var(--t1);margin-bottom:6px;line-height:1.2}
.tool-body{font-size:0.84rem;color:var(--t2);line-height:1.65;font-weight:300;margin-bottom:14px}
.tool-chips{display:flex;flex-wrap:wrap;gap:5px}
.tool-chip{font-family:var(--mono);font-size:0.61rem;color:var(--t3);background:var(--surface);border:1px solid var(--rim);padding:3px 8px;border-radius:5px}
.tool-impact{
  margin-top:12px;padding-top:12px;border-top:1px solid var(--rim);
  font-family:var(--mono);font-size:0.65rem;color:var(--em);letter-spacing:0.01em;
}

/* ════════════════════════════════════
   SKILLS
════════════════════════════════════ */
.skills-wrap{display:grid;grid-template-columns:230px 1fr;gap:2px;border:1px solid var(--rim);border-radius:14px;overflow:hidden;background:var(--rim)}
.skills-nav{background:var(--raised);display:flex;flex-direction:column}
.sk-tab{padding:17px 20px;cursor:pointer;border-bottom:1px solid var(--rim);transition:all 160ms;display:flex;align-items:center;gap:10px}
.sk-tab:last-child{border-bottom:none}
.sk-tab:hover{background:var(--surface)}
.sk-tab.active{background:var(--surface);border-left:2px solid var(--cyan)}
.sk-tab-icon{font-size:0.9rem;opacity:0.7}
.sk-tab-lbl{font-size:0.82rem;color:var(--t2);transition:color 160ms}
.sk-tab.active .sk-tab-lbl{color:var(--t1)}
.skills-panel{background:var(--raised);padding:32px}
.sk-pane{display:none;animation:fadein 220ms var(--ease)}
.sk-pane.active{display:block}
.sk-pane-title{font-family:var(--serif);font-size:1.25rem;font-weight:400;letter-spacing:-0.02em;color:var(--t1);margin-bottom:5px}
.sk-pane-desc{font-size:0.84rem;color:var(--t3);font-weight:300;line-height:1.55;margin-bottom:20px}
.sk-grid{display:flex;flex-wrap:wrap;gap:6px}
.sk{font-family:var(--mono);font-size:0.72rem;color:var(--t2);background:var(--surface);border:1px solid var(--rim);padding:6px 12px;border-radius:7px;transition:all 160ms}
.sk:hover{background:var(--overlay);border-color:var(--rim-h);color:var(--t1);transform:translateY(-1px)}
.sk.core{color:var(--cyan);background:var(--cyan-d);border-color:rgba(20,190,212,0.2)}

/* ════════════════════════════════════
   EXPERIENCE
════════════════════════════════════ */
.exp-list{display:flex;flex-direction:column;gap:2px;border:1px solid var(--rim);border-radius:14px;overflow:hidden;background:var(--rim)}
.exp-card{background:var(--raised);padding:32px;transition:background 160ms}
.exp-card:hover{background:var(--surface)}
.exp-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;gap:20px;flex-wrap:wrap}
.exp-co{font-family:var(--serif);font-size:1.3rem;font-weight:400;letter-spacing:-0.02em;color:var(--t1);line-height:1;margin-bottom:4px}
.exp-role{font-family:var(--mono);font-size:0.68rem;letter-spacing:0.07em;color:var(--cyan);text-transform:uppercase}
.exp-period{font-family:var(--mono);font-size:0.65rem;letter-spacing:0.06em;color:var(--t3);text-transform:uppercase;text-align:right;line-height:1.6}
.exp-buls{list-style:none;display:flex;flex-direction:column;gap:8px}
.exp-buls li{font-size:0.87rem;color:var(--t2);line-height:1.68;font-weight:300;padding-left:16px;position:relative}
.exp-buls li::before{content:'—';position:absolute;left:0;color:var(--t3);font-size:0.72rem}
.exp-buls strong{color:var(--t1);font-weight:500}

/* ════════════════════════════════════
   CONTACT
════════════════════════════════════ */
.contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.contact-h{font-family:var(--serif);font-size:clamp(1.9rem,3.2vw,2.8rem);font-weight:400;letter-spacing:-0.03em;line-height:1.1;color:var(--t1);margin-bottom:16px}
.contact-h em{font-style:italic;color:var(--t2)}
.contact-body{font-size:0.91rem;color:var(--t2);line-height:1.78;font-weight:300;margin-bottom:28px}
.clinks{border:1px solid var(--rim);border-radius:12px;overflow:hidden}
